#!/usr/bin/env bash

# Usage: git wt-rm <folder-name-or-branch-name>

set -e

TARGET="$1"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

if [ -z "$TARGET" ]; then
    echo -e "${RED}Error: Target (folder or branch name) is required${NC}"
    echo "Usage: git wt-rm <folder-name-or-branch-name>"
    exit 1
fi

# 1. Ask Git for all worktrees and figure out the exact path and branch name
WORKTREE_PATH=""
BRANCH_NAME="$TARGET" # Assume the target is the branch name by default

while read -r line; do
    [ -z "$line" ] && continue
    
    # Extract the path (the first column in 'git worktree list')
    path=$(echo "$line" | awk '{print $1}')
    
    # Extract the branch name (everything inside the brackets at the end of the line)
    branch=$(echo "$line" | grep -o '\[.*\]$' | tr -d '[]' || true)
    
    # Check if the path ends with our target folder OR if the branch exactly matches our target
    if [[ "$path" == *"/$TARGET" ]] || [[ "$branch" == "$TARGET" ]]; then
        WORKTREE_PATH="$path"
        if [ -n "$branch" ]; then
            BRANCH_NAME="$branch"
        fi
        break
    fi
done <<< "$(git worktree list)"

# Fallback: If the worktree is already gone but you typed the short folder name (e.g. JIRA-1234), 
# try to guess the branch name so we can still clean it up.
if [ -z "$WORKTREE_PATH" ] && ! git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    MATCHING_BRANCH=$(git branch --list "${TARGET}*" --format="%(refname:short)" | head -n 1)
    if [ -n "$MATCHING_BRANCH" ]; then
        BRANCH_NAME="$MATCHING_BRANCH"
    fi
fi

echo -e "${BLUE}Cleaning up worktree and branch for: $BRANCH_NAME${NC}"

# 2. Handle the Worktree
if [ -n "$WORKTREE_PATH" ]; then
    # Safety check: Prevent deleting the folder if you are currently inside it!
    if [[ "$(pwd)" == "$WORKTREE_PATH"* ]]; then
        echo -e "${RED}Error: You are currently inside the worktree you are trying to delete!${NC}"
        echo -e "Please 'cd' into a different folder (like your bare repo or main worktree) and try again."
        exit 1
    fi

    echo -e "${GREEN}[1/2] Removing worktree folder and configuration...${NC}"
    git worktree remove "$WORKTREE_PATH" --force
else
    echo -e "${YELLOW}Worktree for '$TARGET' not found (it may have already been removed).${NC}"
fi

# 3. Handle the Local Branch
if git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    echo -e "${GREEN}[2/2] Deleting local branch...${NC}"
    git branch -D "$BRANCH_NAME"
else
    echo -e "${YELLOW}Local branch '$BRANCH_NAME' does not exist.${NC}"
fi

echo -e "\n${BLUE}✓ Clean up complete! Workspace is tidy.${NC}"
